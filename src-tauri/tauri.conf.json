{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcrever",
  "version": "0.1.0",
  "identifier": "com.transcrever",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Transcrever",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi"],
    "icon": [],
    "resources": ["resources/*"],
    "externalBin": [],
    "copyright": "Copyright © 2025",
    "category": "Productivity",
    "shortDescription": "Offline audio transcription",
    "longDescription": "Upload Portuguese audio, transcribe locally with Whisper, edit and export as TXT or DOCX.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {}
}
